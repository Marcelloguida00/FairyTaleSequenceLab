/* English Story Book Scenes */
"story.redhood.scene1.title" = "Escena 1";
"story.redhood.scene1.text1" = "Érase una vez, en lo profundo de un espeso bosque, había una pequeña cabaña donde vivía una niña encantadora. Todos la llamaban Caperucita Roja porque su madre le había hecho un precioso manto rojo con capucha a juego.";
"story.redhood.scene1.text2" = "Una mañana, su madre le dijo: \"La abuela está en cama enferma con un fuerte resfriado. Llévale esta cesta de pasteles recién hechos, pero recuerda: ¡sigue por el camino principal y no te detengas!\".\n\nLa pequeña se despidió de su madre con un beso y le prometió: \"¡No te preocupes, mamá! Caminaré rápido e iré directa a casa de la abuela\".";

"story.redhood.scene2.title" = "Escena 2";
"story.redhood.scene2.text1" = "Sin embargo, tan pronto como entró en el bosque, olvidó su promesa. Vio un huerto de deliciosas fresas silvestres y deliciosas flores, así que dejó su canasta.";
"story.redhood.scene2.text2" = "\"¡A la abuela le encantarán!\" pensó, corriendo para recogerlos.\n\nDe repente, se dio cuenta de lo tarde que era, se apresuró a coger su cesta y se apresuró por el sendero.";

"story.redhood.scene3.title" = "Escena 3";
"story.redhood.scene3.text1" = "A medida que el bosque se oscurecía, un lobo grande y oscuro salió de detrás de los árboles. El corazón de Caperucita Roja empezó a acelerarse.\n\n\"¿A dónde vas sola, pequeña?\" preguntó el lobo con voz profunda.";
"story.redhood.scene3.text2" = "\"Voy a la cabaña de mi abuela al final de este camino para llevarle unos pasteles\", respondió tímidamente.\n\nEl astuto lobo ideó un plan rápido. \"¡Que tengas un buen viaje!\" dijo, y al instante desapareció entre los arbustos.";

"story.redhood.scene4.title" = "Escena 4";
"story.redhood.scene4.text1" = "El lobo corrió lo más rápido que pudo, pensando sólo en su próxima comida. Llegó a la cabaña y llamó suavemente a la puerta. ¡Golpear! ¡Golpear!";
"story.redhood.scene4.text2" = "\"¿Quién es?\" preguntó la abuela.\n\n\"¡Soy yo, Caperucita Roja!\" respondió el lobo, disimulando su voz.\n\n\"Entra, querida, la puerta está abierta\", dijo la anciana.";

"story.redhood.scene5.title" = "escena 5";
"story.redhood.scene5.text1" = "El lobo irrumpió en la habitación, pero la astuta abuela se escondió rápidamente dentro del armario para evitar ser encontrada.";
"story.redhood.scene5.text2" = "Al encontrar la habitación vacía, el lobo se puso el gorro de dormir, se metió en la cama y levantó las mantas.";

"story.redhood.scene6.title" = "escena 6";
"story.redhood.scene6.text1" = "Poco después llegó Caperucita Roja y llamó a la puerta.\n\n\"Entra, mi dulce niña\", susurró el lobo, tratando de sonar dulce.";
"story.redhood.scene6.text2" = "La niña entró pero notó que algo era muy extraño.";

"story.redhood.scene7.title" = "Escena 7";
"story.redhood.scene7.text1" = "\"¡Ay, abuela, qué voz tan profunda tienes!\"\n\n\"Será mejor para hablar contigo, querida.\"\n\n\"¡Y qué ojos tan grandes tienes!\"\n\n\"Será mejor verte, querida.\"";
"story.redhood.scene7.text2" = "\"¡Y qué manos tan grandes tienes!\"\n\n\"Será mejor abrazarte, querida.\"\n\n\"Pero abuela... ¡qué boca tan gigante tienes!\" ella jadeó.\n\n\"¡Para COMERTE mejor!\" rugió el lobo.\n\nSaltó de la cama, pero Caperucita Roja, aterrorizada, ¡empezó a gritar tan fuerte como podía!";

"story.redhood.scene8.title" = "Escena 8";
"story.redhood.scene8.text1" = "Un leñador que pasaba por allí escuchó los fuertes gritos de Caperucita Roja provenientes de la cabaña. Corrió lo más rápido que pudo y atravesó la puerta con un gran palo de madera.\n\nAl ver al valiente leñador, el lobo cobarde entró en pánico, saltó por la ventana y corrió hacia lo profundo del bosque, para nunca más ser visto.";
"story.redhood.scene8.text2" = "Al enterarse de que el peligro había pasado, la abuela finalmente salió del armario.\n\nCaperucita Roja y su abuela se abrazaron fuertemente, muy felices de estar por fin completamente sanas y salvas. Agradecieron de todo corazón al valiente leñador por salvarles la vida.";

