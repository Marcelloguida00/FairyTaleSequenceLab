/* Italian Story Book Scenes */
"story.redhood.scene1.title" = "Scena 1";
"story.redhood.scene1.text1" = "C'era una volta, nel fitto di una grande foresta, una piccola casetta dove viveva una graziosa bambina. Tutti la chiamavano Cappuccetto Rosso perché la sua mamma le aveva cucito un bellissimo mantello rosso con un cappuccio abbinato.";
"story.redhood.scene1.text2" = "Una mattina, la mamma le disse: \"La nonna è a letto con un brutto raffreddore. Portale questo cestino di dolci freschi, ma ricorda: resta sul sentiero principale e non fermarti per nessun motivo!\"\n\nLa bambina salutò la mamma con un bacio e promise: \"Non preoccuparti, mamma! Camminerò veloce e andrò dritta a casa della nonna.\"";

"story.redhood.scene2.title" = "Scena 2";
"story.redhood.scene2.text1" = "Tuttavia, non appena entrò nel bosco, dimenticò la sua promessa. Vide una macchia di deliziose fragoline di bosco e dei fiori meravigliosi, così posò il cestino a terra.";
"story.redhood.scene2.text2" = "\"Alla nonna piaceranno tantissimo!\" pensò, correndo qua e là per raccoglierli.\n\nImprovvisamente, si rese conto di quanto fosse tardi, tornò in fretta a prendere il cestino e riprese a camminare velocemente lungo il sentiero.";

"story.redhood.scene3.title" = "Scena 3";
"story.redhood.scene3.text1" = "Mentre il bosco diventava più scuro, un grosso lupo nero sbucò da dietro gli alberi. Il cuore di Cappuccetto Rosso iniziò a battere forte.\n\n\"Dove stai andando tutta sola, bambina?\" le chiese il lupo con voce profonda.";
"story.redhood.scene3.text2" = "\"Sto andando alla casetta di mia nonna, alla fine di questo sentiero, per portarle dei dolci,\" rispose lei timidamente.\n\nL'astuto lupo escogitò subito un piano. \"Buon viaggio!\" disse, e scomparve all'istante tra i cespugli.";
"a11y.button_select_app_icon" = "Seleziona l'icona dell'app";
"a11y.button_locked"          = "Questo elemento è bloccato";
"a11y.button_open_social_link" = "Apri link dei social media";
"a11y.hint_adjust_slider"     = "Regola il cursore con i tasti freccia su e giù";
"a11y.source_tray"            = "Carte sorgente";
"a11y.source_tray_hint"       = "Trascina le carte da qui negli slot";
"a11y.continue_button"        = "Continua";
"a11y.continue_hint"          = "Passa all'evento successivo";
"a11y.envelope_open_button"   = "Apri pacco";
"a11y.envelope_open_hint"     = "Apri la busta per rivelare le carte sbloccare";

"story.redhood.scene4.title" = "Scena 4";
"story.redhood.scene4.text1" = "Il lupo corse più veloce che poté, pensando solo al suo prossimo pasto. Arrivò alla casetta e bussò dolcemente alla porta. Toc! Toc!";
"story.redhood.scene4.text2" = "\"Chi è?\" chiese la nonna.\n\n\"Sono io, Cappuccetto Rosso!\" rispose il lupo, camuffando la voce.\n\n\"Entra, cara, la porta è aperta,\" disse l'anziana signora.";

"story.redhood.scene5.title" = "Scena 5";
"story.redhood.scene5.text1" = "Il lupo irruppe nella stanza, ma l'astuta nonna si nascose rapidamente dentro l'armadio per non farsi trovare.";
"story.redhood.scene5.text2" = "Trovando la stanza vuota, il lupo indossò la sua cuffia da notte, si infilò nel letto e tirò su le coperte.";

"story.redhood.scene6.title" = "Scena 6";
"story.redhood.scene6.text1" = "Poco dopo, Cappuccetto Rosso arrivò e bussò.\n\n\"Entra, mia dolce bambina,\" sussurrò il lupo, cercando di sembrare affettuoso.";
"story.redhood.scene6.text2" = "La bambina entrò, ma notò che c'era qualcosa di molto strano.";

"story.redhood.scene7.title" = "Scena 7";
"story.redhood.scene7.text1" = "\"Oh, nonna, che voce profonda che hai!\"\n\n\"Per parlarti meglio, bambina mia.\"\n\n\"E che occhi grandi che hai!\"\n\n\"Per guardarti meglio, bambina mia.\"";
"story.redhood.scene7.text2" = "\"E che mani grandi che hai!\"\n\n\"Per abbracciarti meglio, bambina mia.\"\n\n\"Ma nonna... che bocca gigante che hai!\" sussultò lei.\n\n\"Per MANGIARTI meglio!\" ruggì il lupo.\n\nSaltò giù dal letto, ma Cappuccetto Rosso, terrorizzata, iniziò a urlare con tutto il fiato che aveva in gola!";

"story.redhood.scene8.title" = "Scena 8";
"story.redhood.scene8.text1" = "Un taglialegna che passava di lì sentì le forti urla di Cappuccetto Rosso provenire dalla casetta. Corse più veloce che poté e sfondò la porta con un grosso bastone di legno.\n\nVedendo il coraggioso taglialegna, il lupo codardo andò nel panico, saltò fuori dalla finestra e fuggì nel fitto del bosco, per non farsi mai più vedere.";
"story.redhood.scene8.text2" = "Sentendo che il pericolo era passato, la nonna finalmente uscì dall'armadio.\n\nCappuccetto Rosso e la sua nonna si abbracciarono forte, così felici di essere finalmente sane e salve. Ringraziarono il coraggioso taglialegna con tutto il cuore per aver salvato loro la vita.";

