/* Italian Story Book Scenes */
"story.redhood.scene1.title" = "Scena 1 — Il cestino per la nonna";
"story.redhood.scene1.text1" = "Cappuccetto Rosso era a casa con la sua mamma. Era una mattina tranquilla, ma la mamma era un po’ preoccupata perché la nonna non si sentiva bene.\n\nAllora prese un cestino e cominciò a riempirlo con cose buone: pane morbido, frutta fresca, una piccola focaccia e qualcosa di caldo da portare alla nonna.";
"story.redhood.scene1.text2" = "«Cappuccetto Rosso,» disse la mamma con dolcezza, «puoi portare questo cestino alla nonna? Le farà piacere ricevere una visita.»\n\nCappuccetto Rosso sorrise. Indossò il suo mantello rosso, prese il cestino con cura e salutò la mamma.\n\nPoi aprì la porta di casa e uscì, pronta a camminare verso la casa della nonna.";

"story.redhood.scene2.title" = "Scena 2 — Il cammino nella foresta";
"story.redhood.scene2.text1" = "Cappuccetto Rosso entrò nella foresta seguendo il sentiero che conosceva bene. Camminava piano, tenendo stretto il cestino tra le mani.\n\nIntorno a lei c’erano alberi alti, foglie verdi e tanti piccoli suoni.";
"story.redhood.scene2.text2" = "Gli uccellini cantavano sui rami e alcune farfalle volavano leggere tra i fiori.\n\nCappuccetto Rosso si fermò per un momento a guardare i fiori colorati vicino al sentiero. Erano belli e profumati.\n\nPoi si ricordò della nonna e riprese a camminare.\n\n«Devo arrivare presto,» pensò. «La nonna mi sta aspettando.»";

"story.redhood.scene3.title" = "Scena 3 — L’incontro con il lupo";
"story.redhood.scene3.text1" = "Mentre Cappuccetto Rosso camminava lungo il sentiero, da dietro un albero comparve un lupo.\n\nIl lupo la guardò e le parlò con voce gentile.\n\n«Buongiorno, bambina. Dove vai con quel bel cestino?»";
"story.redhood.scene3.text2" = "Cappuccetto Rosso, che era educata, rispose: «Sto andando dalla mia nonna. Non si sente bene e le porto qualcosa da mangiare.»\n\nIl lupo ascoltò con attenzione. Poi fece un sorriso furbo.\n\n«Che brava bambina,» disse.\n\nMa dentro di sé il lupo stava già pensando a un piano per arrivare prima di lei alla casa della nonna.";

"story.redhood.scene4.title" = "Scena 4 — Il lupo corre dalla nonna";
"story.redhood.scene4.text1" = "Appena Cappuccetto Rosso riprese il cammino, il lupo corse via veloce attraverso la foresta.\n\nPassò tra gli alberi, saltò sopra le radici e seguì una scorciatoia nascosta.";
"story.redhood.scene4.text2" = "In poco tempo arrivò davanti alla casa della nonna. La casetta era piccola e tranquilla, con una porta di legno e una finestra vicino al giardino.\n\nIl lupo si avvicinò alla porta e bussò.\n\nToc, toc, toc.\n\nDa dentro, la nonna chiese: «Chi è?»\n\nIl lupo cercò di fare una voce dolce e rispose: «Sono io, Cappuccetto Rosso.»";

"story.redhood.scene5.title" = "Scena 5 — Il lupo finge di essere la nonna";
"story.redhood.scene5.text1" = "Il lupo entrò nella casa della nonna. La nonna, capendo che qualcosa non andava, si nascose al sicuro in una piccola stanza.";
"story.redhood.scene5.text2" = "Il lupo, invece, andò nella camera della nonna. Vide il suo letto, il suo cuscino e il suo berretto da notte.\n\nAllora si mise il berretto della nonna e si infilò sotto le coperte. Cercò di sembrare proprio come lei.\n\nPoi rimase fermo nel letto, aspettando Cappuccetto Rosso.\n\nLa stanza era silenziosa, ma il lupo teneva le orecchie ben aperte.";

"story.redhood.scene6.title" = "Scena 6 — Cappuccetto Rosso arriva alla casa";
"story.redhood.scene6.text1" = "Dopo aver camminato ancora un po’, Cappuccetto Rosso arrivò finalmente alla casa della nonna.\n\nSi fermò davanti alla porta e bussò piano.\n\nToc, toc, toc.";
"story.redhood.scene6.text2" = "Da dentro si sentì una voce strana, un po’ roca.\n\n«Entra pure, bambina mia.»\n\nCappuccetto Rosso rimase sorpresa. La voce della nonna sembrava diversa dal solito.\n\nAprì piano la porta, entrò nella casa e si avvicinò alla camera.";

"story.redhood.scene7.title" = "Scena 7 — Qualcosa non va";
"story.redhood.scene7.text1" = "Cappuccetto Rosso entrò nella camera e vide la “nonna” sdraiata nel letto. Si avvicinò con attenzione.\n\nGuardò il viso sotto il berretto e capì subito che qualcosa era strano.\n\n«Nonna,» disse, «che orecchie grandi che hai!»\n\n«Sono per sentirti meglio,» rispose il lupo.";
"story.redhood.scene7.text2" = "Cappuccetto Rosso fece un altro passo.\n\n«Nonna, che occhi grandi che hai!»\n\n«Sono per vederti meglio,» disse il lupo.\n\nPoi Cappuccetto Rosso vide i denti.\n\n«Nonna… che denti grandi che hai!»\n\nA quel punto capì che quella non era la sua nonna.";

"story.redhood.scene8.title" = "Scena 8 — Il lieto finale";
"story.redhood.scene8.text1" = "Cappuccetto Rosso si spaventò e chiamò subito aiuto.\n\n«Aiuto! Aiuto!»\n\nLa sua voce arrivò fuori dalla casa. Poco dopo, alcune persone che passavano vicino al sentiero sentirono il grido e corsero alla casetta della nonna.";
"story.redhood.scene8.text2" = "Il lupo, vedendo arrivare aiuto, si spaventò a sua volta. Saltò giù dal letto e scappò via nella foresta, senza voltarsi indietro.\n\nLa nonna uscì dalla piccola stanza dove si era nascosta. Cappuccetto Rosso corse ad abbracciarla.\n\nFinalmente erano entrambe al sicuro.\n\nLa nonna sorrise e disse: «Grazie, bambina mia. Sei stata coraggiosa.»\n\nCappuccetto Rosso sorrise anche lei. Da quel giorno imparò che, quando si cammina da soli, bisogna sempre stare attenti e non fidarsi degli sconosciuti.";

