/* Persian Story Book Scenes */
"story.redhood.scene1.title" = "صحنه ۱ — سبدی برای مادربزرگ";
"story.redhood.scene1.text" = "شنل قرمزی با مادرش در خانه بود. صبح آرامی بود، اما مادر کمی نگران بود چون مادربزرگ حالش خوب نبود.\n\nبنابراین سبدی برداشت و شروع کرد به پر کردن آن با چیزهای خوب: نان نرم، میوه تازه، یک کلوچه کوچک و چیزی گرم برای بردن به مادربزرگ.\n\n«شنل قرمزی،» مادر با مهربانی گفت، «می‌توانی این سبد را برای مادربزرگ ببری؟ او از دیدن تو خوشحال خواهد شد.»\n\nشنل قرمزی لبخند زد. او شنل قرمزش را پوشید، سبد را با دقت برداشت و با مادرش خداحافظی کرد.\n\nسپس در خانه را باز کرد و بیرون رفت، آماده برای پیاده‌روی به سمت خانه مادربزرگ.";

"story.redhood.scene2.title" = "صحنه ۲ — راه جنگل";
"story.redhood.scene2.text" = "شنل قرمزی وارد جنگل شد و همان راهی را که به خوبی می‌شناخت دنبال کرد. او به آرامی راه می‌رفت و سبد را محکم در دستانش گرفته بود.\n\nدور تا دور او درختان بلند، برگ‌های سبز و صداهای کوچک بسیاری بود. پرندگان روی شاخه‌ها آواز می‌خواندند و پروانه‌ها سبک‌بال میان گل‌ها پرواز می‌کردند.\n\nشنل قرمزی برای لحظه‌ای ایستاد تا به گل‌های رنگارنگ کنار مسیر نگاه کند. آن‌ها زیبا و خوش‌بو بودند.\n\nسپس مادربزرگ را به یاد آورد و دوباره به راه افتاد.\n\nاو با خود فکر کرد: «باید زود برسم، مادربزرگ منتظر من است.»";

"story.redhood.scene3.title" = "صحنه ۳ — ملاقات با گرگ";
"story.redhood.scene3.text" = "هنگامی که شنل قرمزی در طول مسیر راه می‌رفت، گرگی از پشت درختی ظاهر شد.\n\nگرگ به او نگاه کرد و با صدایی مهربان با او صحبت کرد.\n\n«صبح بخیر دخترم. با آن سبد زیبا کجا می‌روی؟»\n\nشنل قرمزی که باادب بود پاسخ داد: «دارم به خانه مادربزرگم می‌روم. حالش خوب نیست و برایش کمی غذا می‌برم.»\n\nگرگ با دقت گوش داد. سپس لبخند زیرکانه‌ای زد.\n\nاو گفت: «چه دختر خوبی.»\n\nاما در درون خود، گرگ از قبل به نقشه‌ای فکر می‌کرد تا زودتر از او به خانه مادربزرگ برسد.";

"story.redhood.scene4.title" = "صحنه ۴ — گرگ به سمت خانه مادربزرگ می‌دود";
"story.redhood.scene4.text" = "به محض اینکه شنل قرمزی دوباره به راه افتاد، گرگ با سرعت از میان جنگل دوید.\n\nاو از بین درختان گذشت، از روی ریشه‌ها پرید و یک میانبر مخفی را دنبال کرد.\n\nدر مدت کوتاهی به جلوی خانه مادربزرگ رسید. کلبه کوچک و آرام بود، با یک در چوبی و پنجره‌ای نزدیک باغچه.\n\nگرگ به در نزدیک شد و ضربه زد.\n\nتق، تق، تق.\n\nاز داخل، مادربزرگ پرسید: «کیست؟»\n\nگرگ سعی کرد صدایش را نرم کند و پاسخ داد: «منم، شنل قرمزی.»";

"story.redhood.scene5.title" = "صحنه ۵ — گرگ وانمود می‌کند که مادربزرگ است";
"story.redhood.scene5.text" = "گرگ وارد خانه مادربزرگ شد. مادربزرگ که فهمید اوضاع خوب نیست، با امنیت در اتاق کوچکی پنهان شد.\n\nدر عوض، گرگ به اتاق خواب مادربزرگ رفت. تخت، بالش و کلاه خواب او را دید.\n\nبنابراین کلاه خواب مادربزرگ را سرش گذاشت و به زیر پتو رفت. او سعی کرد دقیقاً شبیه او به نظر برسد.\n\nسپس روی تخت بی‌حرکت ماند و منتظر شنل قرمزی شد.\n\nاتاق ساکت بود، اما گرگ گوش‌هایش را کاملاً تیز نگه داشته بود.";

"story.redhood.scene6.title" = "صحنه ۶ — شنل قرمزی به خانه می‌رسد";
"story.redhood.scene6.text" = "پس از کمی پیاده‌روی دیگر، شنل قرمزی بالاخره به خانه مادربزرگ رسید.\n\nجلوی در ایستاد و به آرامی ضربه زد.\n\nتق، تق، تق.\n\nاز داخل صدایی عجیب و کمی گرفته شنیده شد.\n\n«بیا داخل، فرزندم.»\n\nشنل قرمزی تعجب کرد. صدای مادربزرگ متفاوت از همیشه به نظر می‌رسید.\n\nدر را به آرامی باز کرد، وارد خانه شد و به اتاق خواب نزدیک شد.";

"story.redhood.scene7.title" = "صحنه ۷ — چیزی درست نیست";
"story.redhood.scene7.text" = "شنل قرمزی وارد اتاق خواب شد و «مادربزرگ» را دید که روی تخت دراز کشیده است.\n\nبا احتیاط نزدیک شد. به صورت زیر کلاه نگاه کرد و بلافاصله فهمید که چیزی عجیب است.\n\nاو گفت: «مادربزرگ، چه گوش‌های بزرگی داری!»\n\nگرگ پاسخ داد: «برای اینکه صدای تو را بهتر بشنوم.»\n\nشنل قرمزی یک قدم دیگر برداشت.\n\n«مادربزرگ، چه چشم‌های بزرگی داری!»\n\nگرگ گفت: «برای اینکه تو را بهتر ببینم.»\n\nسپس شنل قرمزی دندان‌ها را دید.\n\n«مادربزرگ... چه دندان‌های بزرگی داری!»\n\nدر آن لحظه متوجه شد که او مادربزرگش نیست.";

"story.redhood.scene8.title" = "صحنه ۸ — پایان خوش";
"story.redhood.scene8.text" = "شنل قرمزی ترسید و بلافاصله کمک خواست.\n\n«کمک! کمک!»\n\nصدای او به بیرون از خانه رسید. کمی بعد، چند نفر که از نزدیکی مسیر عبور می‌کردند صدا را شنیدند و به سمت کلبه مادربزرگ دویدند.\n\nگرگ با دیدن نیروی کمکی، خودش هم ترسید. از روی تخت پرید و بدون اینکه به پشت سر نگاه کند به داخل جنگل فرار کرد.\n\nمادربزرگ از اتاق کوچکی که در آن پنهان شده بود بیرون آمد. شنل قرمزی به سمت او دوید تا او را در آغوش بگیرد.\n\nسرانجام هر دو در امان بودند.\n\nمادربزرگ لبخند زد و گفت: «ممنون فرزندم. تو بسیار شجاع بودی.»\n\nشنل قرمزی هم لبخند زد. از آن روز او یاد گرفت که وقتی تنهایی راه می‌رود، همیشه باید مراقب باشد و به غریبه‌ها اعتماد نکند.";

