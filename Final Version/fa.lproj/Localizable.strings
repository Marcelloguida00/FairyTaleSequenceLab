/* English Story Book Scenes */
"story.redhood.scene1.title" = "صحنهٔ ۱";
"story.redhood.scene1.text1" = "روزی روزگاری، در دل جنگلی انبوه، کلبهٔ کوچکی بود که دخترکی دوست‌داشتنی در آن زندگی می‌کرد. همه او را شنل‌قرمزی صدا می‌زدند، چون مادرش برایش شنل قرمز زیبایی با کلاهی همرنگ دوخته بود.";
"story.redhood.scene1.text2" = "یک روز صبح مادرش گفت: «مادربزرگ سرما خورده و در رختخواب است. این سبد کلوچه‌های تازه را برایش ببر، اما یادت باشد: از راه اصلی بیرون نرو و جایی توقف نکن!»\n\nدخترک مادرش را بوسید و قول داد: «نگران نباش مامان! تند می‌روم و یکراست به خانهٔ مادربزرگ می‌رسم.»";

"story.redhood.scene2.title" = "صحنهٔ ۲";
"story.redhood.scene2.text1" = "اما همین که وارد جنگل شد، قولش را فراموش کرد. یک دشت پر از توت‌فرنگی‌های وحشی خوشمزه و گل‌های قشنگ دید و سبدش را زمین گذاشت.";
"story.redhood.scene2.text2" = "با خودش فکر کرد: «مادربزرگ عاشق این‌ها می‌شود!» و این‌طرف و آن‌طرف دوید تا آنها را بچیند.\n\nناگهان فهمید چقدر دیر شده است؛ با عجله برگشت، سبدش را برداشت و به‌سرعت در مسیر به راه افتاد.";

"story.redhood.scene3.title" = "صحنهٔ ۳";
"story.redhood.scene3.text1" = "هرچه جنگل تاریک‌تر می‌شد، ناگهان گرگی بزرگ و سیاه از پشت درخت‌ها بیرون آمد. قلب شنل‌قرمزی تند تند زد.\n\nگرگ با صدایی بم پرسید: «دختر کوچولو، تنهایی کجا می‌روی؟»";
"story.redhood.scene3.text2" = "او با خجالت جواب داد: «به کلبهٔ مادربزرگم در انتهای همین راه می‌روم تا برایش کلوچه ببرم.»\n\nگرگ حیله‌گر فوری نقشه‌ای کشید. گفت: «سفر بی‌خطر!» و در یک چشم به‌هم زدن میان بوته‌ها ناپدید شد.";

"story.redhood.scene4.title" = "صحنهٔ ۴";
"story.redhood.scene4.text1" = "گرگ با تمام سرعت دوید و فقط به وعدهٔ غذای بعدی‌اش فکر می‌کرد. به کلبه رسید و آرام در زد. تق! تق!";
"story.redhood.scene4.text2" = "مادربزرگ پرسید: «کیه؟»\n\nگرگ با تغییر دادن صدایش جواب داد: «منم، شنل‌قرمزی!»\n\nپیرزن گفت: «بیا تو عزیزم، در باز است.»";

"story.redhood.scene5.title" = "صحنهٔ ۵";
"story.redhood.scene5.text1" = "گرگ به داخل اتاق هجوم برد، اما مادربزرگ زیرک فوری داخل کمد پنهان شد تا پیدا نشود.";
"story.redhood.scene5.text2" = "گرگ که اتاق را خالی دید، کلاه‌خواب مادربزرگ را سرش گذاشت، در تختش دراز کشید و لحاف را روی خودش کشید.";

"story.redhood.scene6.title" = "صحنهٔ ۶";
"story.redhood.scene6.text1" = "کمی بعد شنل‌قرمزی رسید و در زد.\n\nگرگ زمزمه کرد: «بیا تو، دخترک شیرینم» و سعی کرد صدایش مهربان باشد.";
"story.redhood.scene6.text2" = "دخترک داخل شد، اما حس کرد چیزی خیلی عجیب است.";

"story.redhood.scene7.title" = "صحنهٔ ۷";
"story.redhood.scene7.text1" = "«وای مادربزرگ، چه صدای کلفتی داری!»\n\n«برای اینکه بهتر با تو حرف بزنم، عزیزم.»\n\n«و چه چشم‌های بزرگی داری!»\n\n«برای اینکه بهتر تو را ببینم، عزیزم.»";
"story.redhood.scene7.text2" = "«و چه دست‌های بزرگی داری!»\n\n«برای اینکه بهتر بغلت کنم، عزیزم.»\n\nدخترک با ترس گفت: «اما مادربزرگ... چه دهان بزرگی داری!»\n\nگرگ غرید: «برای اینکه بهتر تو را بخورم!»\n\nگرگ از تخت بیرون پرید، اما شنل‌قرمزیِ وحشت‌زده با تمام توانش شروع به جیغ زدن کرد!";

"story.redhood.scene8.title" = "صحنهٔ ۸";
"story.redhood.scene8.text1" = "هیزم‌شکنی که از آن حوالی می‌گذشت، صدای جیغ‌های بلند شنل‌قرمزی را از کلبه شنید. با تمام سرعت دوید و با چوبی بزرگ در را شکست و وارد شد.\n\nگرگ ترسو با دیدن هیزم‌شکن شجاع وحشت کرد، از پنجره بیرون پرید و به اعماق جنگل گریخت و دیگر هرگز دیده نشد.";
"story.redhood.scene8.text2" = "مادربزرگ که فهمید خطر رفع شده، بالاخره از کمد بیرون آمد.\n\nشنل‌قرمزی و مادربزرگ محکم همدیگر را بغل کردند و از اینکه بالاخره صحیح و سالم بودند بسیار خوشحال شدند. آن دو از صمیم قلب از هیزم‌شکن شجاع برای نجات جانشان تشکر کردند.";

