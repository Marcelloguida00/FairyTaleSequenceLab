/* French Story Book Scenes */
"story.redhood.scene1.title" = "Scène 1";
"story.redhood.scene1.text1" = "Il était une fois, au plus profond d'une forêt dense, une petite maisonnette où vivait une jolie petite fille. Tout le monde l'appelait le Petit Chaperon Rouge parce que sa maman lui avait confectionné un magnifique manteau rouge avec un capuchon assorti.";
"story.redhood.scene1.text2" = "Un matin, sa maman lui dit : « Grand-mère est malade et alitée avec un gros rhume. Apporte-lui ce panier de gâteaux frais, mais souviens-toi : reste bien sur le sentier principal et ne t'arrête pas ! »\n\nLa fillette embrassa sa maman pour lui dire au revoir et promit : « Ne t'inquiète pas, Maman ! Je marcherai vite et j'irai directement chez Grand-mère. »";

"story.redhood.scene2.title" = "Scène 2";
"story.redhood.scene2.text1" = "Cependant, dès qu'elle entra dans la forêt, elle oublia sa promesse. Elle vit un parterre de délicieuses fraises des bois et de merveilleuses fleurs, et posa son panier par terre.";
"story.redhood.scene2.text2" = "« Grand-mère va adorer ça ! » pensa-t-elle, courant çà et là pour les cueillir.\n\nSoudain, elle réalisa à quel point il était tard, se dépêcha de récupérer son panier et reprit rapidement le sentier.";

"story.redhood.scene3.title" = "Scène 3";
"story.redhood.scene3.text1" = "Alors que les bois s'assombrissaient, un grand loup noir surgit de derrière les arbres. Le cœur du Petit Chaperon Rouge se mit à battre la chamade.\n\n« Où vas-tu ainsi toute seule, fillette ? » demanda le loup d'une voix grave.";
"story.redhood.scene3.text2" = "« Je vais à la maisonnette de ma grand-mère, au bout de ce sentier, pour lui apporter des gâteaux, » répondit-elle timidement.\n\nL'astucieux loup échafauda rapidement un plan. « Bon voyage ! » dit-il, et il disparut instantanément dans les buissons.";

"story.redhood.scene4.title" = "Scène 4";
"story.redhood.scene4.text1" = "Le loup courut aussi vite qu'il le put, ne pensant qu'à son prochain repas. Il arriva à la maisonnette et frappa doucement à la porte. Toc ! Toc !";
"story.redhood.scene4.text2" = "« Qui est là ? » demanda la grand-mère.\n\n« C'est moi, le Petit Chaperon Rouge ! » répondit le loup en déguisant sa voix.\n\n« Entre, ma chérie, la porte n'est pas fermée à clé, » dit la vieille dame.";

"story.redhood.scene5.title" = "Scène 5";
"story.redhood.scene5.text1" = "Le loup fit irruption dans la pièce, mais l'astucieuse grand-mère se cacha rapidement dans l'armoire pour ne pas être découverte.";
"story.redhood.scene5.text2" = "Trouvant la pièce vide, le loup enfila sa coiffe de nuit, se glissa dans le lit et remonta les couvertures.";

"story.redhood.scene6.title" = "Scène 6";
"story.redhood.scene6.text1" = "Peu après, le Petit Chaperon Rouge arriva et frappa.\n\n« Entre, ma douce enfant, » murmura le loup, essayant de paraître affectueux.";
"story.redhood.scene6.text2" = "La fillette entra mais remarqua que quelque chose était très étrange.";

"story.redhood.scene7.title" = "Scène 7";
"story.redhood.scene7.text1" = "« Oh, Grand-mère, comme tu as une voix grave ! »\n\n« C'est pour mieux te parler, mon enfant. »\n\n« Et comme tu as de grands yeux ! »\n\n« C'est pour mieux te voir, mon enfant. »";
"story.redhood.scene7.text2" = "« Et comme tu as de grandes mains ! »\n\n« C'est pour mieux t'embrasser, mon enfant. »\n\n« Mais Grand-mère... quelle bouche géante tu as ! » sursauta-t-elle.\n\n« C'est pour mieux te MANGER ! » rugit le loup.\n\nIl sauta hors du lit, mais le Petit Chaperon Rouge, terrifiée, se mit à hurler de toutes ses forces !";

"story.redhood.scene8.title" = "Scène 8";
"story.redhood.scene8.text1" = "Un bûcheron qui passait par là entendit les cris stridents du Petit Chaperon Rouge provenant de la maisonnette. Il courut aussi vite que possible et enfonça la porte avec un grand bâton de bois.\n\nEn voyant le courageux bûcheron, le loup poltron paniqua, sauta par la fenêtre et s'enfuit au plus profond de la forêt pour ne plus jamais réapparaître.";
"story.redhood.scene8.text2" = "Entendant que le danger était écarté, la grand-mère sortit enfin de l'armoire.\n\nLe Petit Chaperon Rouge et sa grand-mère se serrèrent fort dans les bras, si heureuses d'être enfin saines et sauves. Elles remercièrent le courageux bûcheron de tout leur cœur pour leur avoir sauvé la vie.";

