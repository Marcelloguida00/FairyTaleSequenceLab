/* English Story Book Scenes */
"story.redhood.scene1.title" = "Cena 1";
"story.redhood.scene1.text1" = "Era uma vez, no fundo de uma floresta densa, uma pequena casinha onde vivia uma menina adorável. Todos a chamavam de Chapeuzinho Vermelho, porque sua mãe tinha feito para ela uma linda capa vermelha com um capuz combinando.";
"story.redhood.scene1.text2" = "Certa manhã, sua mãe disse: \"A vovó está de cama com um resfriado forte. Leve para ela esta cesta de bolinhos frescos, mas lembre-se: fique no caminho principal e não pare!\"\n\nA menina deu um beijo de despedida na mãe e prometeu: \"Não se preocupe, mamãe! Vou andar depressa e ir direto para a casa da vovó.\"";

"story.redhood.scene2.title" = "Cena 2";
"story.redhood.scene2.text1" = "Porém, assim que entrou na floresta, ela esqueceu sua promessa. Viu um canteiro de morangos silvestres deliciosos e flores encantadoras, e então pousou a cesta no chão.";
"story.redhood.scene2.text2" = "\"A vovó vai adorar!\", pensou ela, correndo de um lado para o outro para colhê-los.\n\nDe repente, percebeu como já era tarde, voltou correndo para pegar a cesta e seguiu apressada pela trilha.";

"story.redhood.scene3.title" = "Cena 3";
"story.redhood.scene3.text1" = "À medida que a mata ficava mais escura, um lobo grande e sombrio saiu de trás das árvores. O coração da Chapeuzinho Vermelho disparou.\n\n\"Aonde você vai sozinha, menina?\", perguntou o lobo com voz grave.";
"story.redhood.scene3.text2" = "\"Vou à casinha da minha avó, no fim deste caminho, levar uns bolinhos para ela\", respondeu ela timidamente.\n\nO lobo astuto bolou rapidamente um plano. \"Boa viagem!\", disse ele, e desapareceu num instante entre os arbustos.";

"story.redhood.scene4.title" = "Cena 4";
"story.redhood.scene4.text1" = "O lobo correu o mais rápido que pôde, pensando apenas na sua próxima refeição. Chegou à casinha e bateu de leve na porta. Toc! Toc!";
"story.redhood.scene4.text2" = "\"Quem é?\", perguntou a vovó.\n\n\"Sou eu, a Chapeuzinho Vermelho!\", respondeu o lobo, disfarçando a voz.\n\n\"Entre, querida, a porta está aberta\", disse a velhinha.";

"story.redhood.scene5.title" = "Cena 5";
"story.redhood.scene5.text1" = "O lobo irrompeu no quarto, mas a vovó esperta se escondeu rapidamente dentro do armário para não ser encontrada.";
"story.redhood.scene5.text2" = "Ao encontrar o quarto vazio, o lobo colocou a touca de dormir dela, subiu na cama e puxou as cobertas.";

"story.redhood.scene6.title" = "Cena 6";
"story.redhood.scene6.text1" = "Pouco depois, a Chapeuzinho Vermelho chegou e bateu à porta.\n\n\"Entre, minha doce menina\", sussurrou o lobo, tentando soar gentil.";
"story.redhood.scene6.text2" = "A menina entrou, mas percebeu que havia algo muito estranho.";

"story.redhood.scene7.title" = "Cena 7";
"story.redhood.scene7.text1" = "\"Ah, vovó, que voz grossa você tem!\"\n\n\"É para falar melhor com você, minha querida.\"\n\n\"E que olhos grandes você tem!\"\n\n\"É para enxergar você melhor, minha querida.\"";
"story.redhood.scene7.text2" = "\"E que mãos grandes você tem!\"\n\n\"É para abraçar você melhor, minha querida.\"\n\n\"Mas vovó... que boca gigante você tem!\", exclamou ela assustada.\n\n\"É para TE COMER melhor!\", rugiu o lobo.\n\nEle pulou da cama, mas a Chapeuzinho Vermelho, apavorada, começou a gritar o mais alto que podia!";

"story.redhood.scene8.title" = "Cena 8";
"story.redhood.scene8.text1" = "Um lenhador que passava por ali ouviu os gritos altos da Chapeuzinho Vermelho vindos da casinha. Ele correu o mais rápido que pôde e arrombou a porta com um grande pedaço de madeira.\n\nAo ver o corajoso lenhador, o lobo covarde entrou em pânico, pulou pela janela e fugiu para o fundo da floresta, para nunca mais ser visto.";
"story.redhood.scene8.text2" = "Ao perceber que o perigo havia passado, a vovó finalmente saiu do armário.\n\nA Chapeuzinho Vermelho e a vovó se abraçaram com força, muito felizes por estarem finalmente sãs e salvas. Elas agradeceram de todo o coração ao corajoso lenhador por ter salvado suas vidas.";

